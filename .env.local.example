# FlowAluminio — Variables de Entorno
# Copiar a .env.local y completar con valores reales
# NUNCA subir este archivo con valores reales al repositorio

# ─── APP ────────────────────────────────────────────────────────────────────
APP_ENV=development
# URL pública del sitio — usada en auth/callback para construir redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xmmgmuyklyaogfllqkfi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_VpkpJhjLF0p-tpWToDr23A_wnRHXd2Y
# Service Role Key — solo para Server Actions con Admin API — NO exponer al browser
SUPABASE_SERVICE_ROLE_KEY=[service-role-key]
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xmmgmuyklyaogfllqkfi.supabase.co:5432/postgres

# ─── SUPABASE: configuración en Dashboard ────────────────────────────────────
# Authentication → URL Configuration:
#   Site URL:     https://[tu-dominio-vercel].vercel.app
#   Redirect URLs (agregar ambas):
#     https://[tu-dominio-vercel].vercel.app/auth/callback
#     http://localhost:3000/auth/callback

# ─── DEPLOY VERCEL — Checklist ────────────────────────────────────────────────
# 1. vercel.com → Add New Project → Import Git Repository
# 2. Framework Preset: Next.js (detectado automático)
# 3. Environment Variables — agregar en Vercel Dashboard:
#      NEXT_PUBLIC_SITE_URL        = https://[tu-dominio].vercel.app
#      NEXT_PUBLIC_SUPABASE_URL    = [mismo que local]
#      NEXT_PUBLIC_SUPABASE_ANON_KEY = [mismo que local]
#      SUPABASE_SERVICE_ROLE_KEY   = [mismo que local]
# 4. Deploy → obtener URL de producción
# 5. Supabase Dashboard → Authentication → URL Configuration:
#      Site URL: https://[tu-dominio].vercel.app
#      Agregar Redirect URL: https://[tu-dominio].vercel.app/auth/callback
# 6. Actualizar NEXT_PUBLIC_SITE_URL en Vercel con la URL real

# ─── EMAIL TRANSACCIONAL (Resend) ────────────────────────────────────────────
RESEND_API_KEY=REEMPLAZAR
EMAIL_FROM=noreply@flowaluminio.com
